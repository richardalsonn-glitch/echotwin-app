# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenRouter free router
# Create a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
