# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Runtime AI providers
# Gemini 2.5 Flash: chat analysis, conversation analysis, image interpretation
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ElevenLabs Creator: voice cloning and text-to-speech
ELEVENLABS_API_KEY=
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_DEFAULT_VOICE_ID=

# Legacy note:
# OpenRouter, Anthropic, and AI_INTEGRATIONS_OPENAI_* are intentionally not used
# by the runtime AI layer anymore. Do not add them for new installs.
