# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenRouter AI provider
# Create a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_APP_NAME=Bendeki Sen

# Optional legacy OpenAI-compatible fallback.
# OpenRouter env vars take priority.
# AI_INTEGRATIONS_OPENAI_API_KEY=
# AI_INTEGRATIONS_OPENAI_BASE_URL=

# Voice input transcription
# Uses OpenAI speech-to-text directly. If omitted, AI_INTEGRATIONS_OPENAI_API_KEY is used as fallback.
AI_TRANSCRIBE_OPENAI_API_KEY=
AI_TRANSCRIBE_OPENAI_BASE_URL=https://api.openai.com/v1
AI_TRANSCRIBE_OPENAI_MODEL=gpt-4o-mini-transcribe
